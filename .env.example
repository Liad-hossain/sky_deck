# ── Server-only environment variables (local dev only) ───────
# In production, secrets are injected via GitHub Actions into
# netlify/functions/secrets/*.json (see .github/workflows/deploy.yml).
#
# For local development, set these in .env — the function code
# falls back to process.env when the JSON files don't exist.

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# GitHub App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_SLUG=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Firebase Realtime DB
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=

# Public app URL (used for email redirect links)
SKY_DECK_APP_URL=
SKY_DECK_GROQ_API_KEY=